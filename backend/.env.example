# ==========================================
# EXEMPLO - Configurações para Produção
# ==========================================
# Copie este arquivo para .env e preencha com seus valores

# 🔐 SEGURANÇA
# Gere uma chave forte com: openssl rand -hex 64
JWT_SECRET=sua-chave-secreta-aqui

# 🌐 SERVIDOR
PORT=3000
NODE_ENV=production

# 🌐 CORS - Domínios permitidos (separados por vírgula)
# Exemplo: https://seudominio.com,https://www.seudominio.com
ALLOWED_ORIGINS=*

# 👤 ADMIN
ADMIN_EMAIL=seu-email@admin.com